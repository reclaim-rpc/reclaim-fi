# ============================================================
# Reclaim Fi Marketing Engine — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you need.
# Any platform whose credentials are left blank will be
# gracefully skipped at runtime (no crash).
# ============================================================

# --- Anthropic (REQUIRED for content generation) ---
ANTHROPIC_API_KEY=

# --- Twitter / X  (OAuth 1.0a) ---
# Create an app at https://developer.twitter.com/en/portal
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
# Bearer token for v2 search endpoints
TWITTER_BEARER_TOKEN=

# --- Reddit (PRAW) ---
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# User-agent string for the Reddit API
REDDIT_USER_AGENT=reclaim-fi-bot/1.0 by /u/reclaimfi

# --- Telegram ---
# Create a bot via @BotFather
TELEGRAM_BOT_TOKEN=
# Channel ID or @channel_username to post to
TELEGRAM_CHANNEL_ID=

# --- Discord ---
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Numeric channel ID where the bot should post
DISCORD_CHANNEL_ID=
